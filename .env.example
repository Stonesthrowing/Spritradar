# Vorlage für lokale Tests. Echte Werte NICHT committen (.env ist in .gitignore).
# In der Produktion kommen diese Werte aus GitHub-Actions-Secrets.

TANKERKOENIG_API_KEY=dein-tankerkoenig-key
TELEGRAM_BOT_TOKEN=dein-bot-token
TELEGRAM_CHAT_ID=deine-chat-id
# ANTHROPIC_API_KEY=dein-anthropic-key   # optional: LLM-Nachrichtenanalyse
# FORCE=1   # setzen, um Zeitfenster/Dedup lokal zu umgehen
